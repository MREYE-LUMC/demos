---
import { getCollection } from "astro:content";
import MainLayout from "../layouts/MainLayout.astro";
import { Icon } from "astro-icon/components";

const demos = (await getCollection("demos")).sort(
  (a, b) => a.data.weight - b.data.weight,
);
---

<MainLayout title="MReye demos">
  <section class="mx-auto max-w-3xl">
    <h1
      class="mb-4 text-4xl font-semibold tracking-tight text-slate-900 sm:text-5xl"
    >
      MReye Demos
    </h1>
    <p class="text-base leading-7 text-slate-700 sm:text-lg">
      Welcome to our demo website! This website hosts a few interactive demos
      related to our research and / or software. Go check them out!
    </p>
  </section>

  <section class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
    {
      demos.map((demo) => (
        <article class="flex h-full flex-col rounded-xl border border-slate-200 bg-white shadow-sm transition hover:shadow-md">
          <div class="border-b border-slate-200 px-5 py-4">
            <h3 class="text-lg font-semibold text-slate-900">
              {demo.data.name}
            </h3>
          </div>
          <div class="flex h-full flex-col gap-4 px-5 py-4">
            <p class="text-sm leading-6 text-slate-700">
              {demo.data.description}
            </p>
            <a
              class="mt-auto inline-flex w-fit items-center rounded-md border border-cyan-700 px-4 py-2 text-sm font-medium text-cyan-700 transition hover:bg-cyan-50"
              href={`/${demo.id}/`}
            >
              <Icon
                name="heroicons:arrow-top-right-on-square"
                is:inline={true}
                class="mr-2"
              />
              Go to demo
            </a>
          </div>
        </article>
      ))
    }
  </section>
</MainLayout>
