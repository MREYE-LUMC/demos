---
import MainLayout from "../layouts/MainLayout.astro";
---

<MainLayout title="Page not found">
  <section class="mx-auto max-w-3xl rounded-2xl border border-slate-200 bg-white p-8 text-center shadow-sm">
    <p class="text-xs font-semibold uppercase tracking-[0.25em] text-cyan-700">Error</p>
    <h1 class="mt-2 text-5xl font-semibold tracking-tight text-slate-900">404</h1>
    <p class="mt-4 text-slate-700">That demo does not exist yet.</p>
    <p class="mt-1 text-slate-600">Check the available demos on the home page.</p>
    <a class="mt-6 inline-flex items-center rounded-md bg-cyan-700 px-4 py-2 text-sm font-medium text-white transition hover:bg-cyan-800" href="/" role="button">Home</a>
  </section>
</MainLayout>
