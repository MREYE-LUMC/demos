---
import { getCollection } from "astro:content";
import "../styles/global.css";

interface Props {
  title: string;
  wide?: boolean;
}

const { title, wide = false } = Astro.props;
const pathname = Astro.url.pathname;
const mainWidthClass = wide ? "max-w-[1500px]" : "max-w-6xl";
const currentYear = new Date().getFullYear();

const demos = (await getCollection("demos")).sort(
  (a, b) => a.data.weight - b.data.weight,
);

const isActive = (prefix: string) =>
  pathname === prefix || pathname.startsWith(`${prefix}/`);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} - MReye demos</title>
    <link rel="icon" type="image/png" href="/_assets/icon.png" />
  </head>
  <body
    class="flex min-h-screen flex-col bg-slate-50 text-slate-800 antialiased"
  >
    <header
      class="site-header sticky top-0 z-50 border-b border-slate-200/80 bg-white/95 backdrop-blur"
    >
      <nav
        class="mx-auto flex w-full max-w-[1500px] items-center justify-between px-4 py-3 sm:px-6"
      >
        <a
          class="inline-flex items-center gap-2 rounded-md px-1 py-1 text-slate-900 transition hover:bg-slate-100"
          href="/"
        >
          <img src="/_assets/icon.png" alt="MReye logo" class="h-7 w-7" />
          <span class="text-sm font-semibold tracking-wide sm:text-base"
            >MReye demos</span
          >
        </a>

        <div class="hidden items-center gap-1 md:flex">
          {
            demos.map((demo) => (
              <a
                class={`rounded-md px-3 py-2 text-sm font-medium transition ${isActive(`/${demo.id}`) ? "bg-cyan-600 text-white" : "text-slate-600 hover:bg-slate-100 hover:text-slate-900"}`}
                href={`/${demo.id}/`}
              >
                {demo.data.name}
              </a>
            ))
          }
          <a
            class="rounded-md px-3 py-2 text-sm font-medium text-slate-600 transition hover:bg-slate-100 hover:text-slate-900"
            href="https://mreye.nl"
            target="_blank"
            rel="noopener">About us</a
          >
          <a
            class="ml-1 inline-flex h-9 w-9 items-center justify-center rounded-md text-slate-500 transition hover:bg-slate-100 hover:text-slate-900"
            href="https://github.com/MREYE-LUMC/demos"
            target="_blank"
            rel="noopener"
            aria-label="GitHub repository"
          >
            <svg
              viewBox="0 0 24 24"
              class="h-5 w-5 fill-current"
              aria-hidden="true"
            >
              <path
                d="M12 .5C5.65.5.5 5.76.5 12.25c0 5.19 3.3 9.59 7.87 11.14.58.11.79-.26.79-.57v-2.02c-3.2.71-3.87-1.58-3.87-1.58-.52-1.37-1.28-1.73-1.28-1.73-1.05-.73.08-.72.08-.72 1.16.08 1.77 1.22 1.77 1.22 1.03 1.81 2.69 1.29 3.35.98.1-.77.4-1.29.73-1.59-2.56-.3-5.26-1.31-5.26-5.85 0-1.3.46-2.36 1.21-3.19-.12-.3-.52-1.52.11-3.18 0 0 .99-.32 3.24 1.22a11 11 0 0 1 5.9 0c2.25-1.54 3.24-1.22 3.24-1.22.63 1.66.23 2.88.11 3.18.75.83 1.21 1.89 1.21 3.19 0 4.56-2.71 5.54-5.3 5.84.42.37.79 1.1.79 2.22v3.29c0 .32.2.69.8.57 4.56-1.55 7.86-5.95 7.86-11.14C23.5 5.76 18.35.5 12 .5Z"
              ></path>
            </svg>
          </a>
        </div>

        <details class="relative md:hidden">
          <summary
            class="list-none rounded-md border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-slate-700 shadow-sm marker:content-none"
            >Menu</summary
          >
          <div
            class="absolute right-0 mt-2 flex min-w-52 flex-col gap-1 rounded-xl border border-slate-200 bg-white p-2 shadow-lg"
          >
            {
              demos.map((demo) => (
                <a
                  class={`rounded-md px-3 py-2 text-sm ${isActive(`/${demo.id}`) ? "bg-cyan-600 text-white" : "text-slate-700 hover:bg-slate-100"}`}
                  href={`/${demo.id}/`}
                >
                  {demo.data.name}
                </a>
              ))
            }
            <a
              class="rounded-md px-3 py-2 text-sm text-slate-700 hover:bg-slate-100"
              href="https://mreye.nl"
              target="_blank"
              rel="noopener">About us</a
            >
            <a
              class="rounded-md px-3 py-2 text-sm text-slate-700 hover:bg-slate-100"
              href="https://github.com/MREYE-LUMC/demos"
              target="_blank"
              rel="noopener">GitHub</a
            >
          </div>
        </details>
      </nav>
    </header>

    <main
      class={`mx-auto w-full flex-1 px-4 pb-16 pt-8 sm:px-6 ${mainWidthClass}`}
    >
      <slot />
    </main>

    <footer
      class="mt-auto border-t border-slate-200 bg-white/80 text-sm text-slate-600"
    >
      <div class="mx-auto w-full max-w-[1500px] px-4 py-4 text-center sm:px-6">
        © 2025 - {currentYear} Jan-Willem Beenakker and the MReye research group.
        Built with
        <a
          href="https://astro.build"
          class="font-medium text-cyan-700 hover:text-cyan-800"
          target="_blank"
          rel="noopener">Astro</a
        >
        and
        <a
          href="https://shiny.posit.co/py/"
          class="font-medium text-cyan-700 hover:text-cyan-800"
          target="_blank"
          rel="noopener">Shiny for Python</a
        >.
      </div>
    </footer>
  </body>
</html>
