{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": [
    "dependencies"
  ],
  "automergeStrategy": "squash",
  "packageRules": [
    {
      "groupName": "Python version",
      "matchFileNames": [
        "pyproject.toml"
      ],
      "matchDepTypes": [
        "requires-python"
      ],
      "enabled": false
    },
    {
      "groupName": "non-major dependencies",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "pin"
      ],
      "automerge": true
    }
  ]
}